rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // 유틸리티 함수
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSuperAdmin() {
      return isAuthenticated() && request.auth.token.email == 'bizpeer@gmail.com';
    }

    // 사용자의 소속 회사 ID를 Firestore(weberp)에서 조회
    function getMyCompanyId() {
      return firestore.get(/databases/weberp/documents/UserProfile/$(request.auth.uid)).data.companyId;
    }

    // 신규 구조: /companies/{companyId}/...
    match /companies/{companyId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && (
        isSuperAdmin() || 
        getMyCompanyId() == companyId
      );
    }
    
    // 레거시 대응: 기존 업로드된 파일들은 URL 내 토큰으로 읽기 가능하므로, 
    // 직접적인 경로 접근은 차단하거나 어드민만 허용
    match /{allPaths=**} {
      allow read: if isSuperAdmin();
      allow write: if isSuperAdmin();
    }
  }
}
