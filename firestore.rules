rules_version = '2';
// Update cache: 2026-04-19

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 유틸리티 함수: 사용자가 인증되었는지 확인
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Firestore 문서의 role 필드를 조회하여 권한을 확인합니다.
    function getUserData() { 
      let path = /databases/$(database)/documents/UserProfile/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }
    
    function getRole() { 
      let data = getUserData();
      return data != null ? data.role : 'GUEST';
    }
    
    function getCompanyId() {
      let data = getUserData();
      return data != null ? data.companyId : '';
    }
    
    // SUPER_ADMIN 확인 (플랫폼 최고 관리자)
    function isSuperAdmin() {
      return isAuthenticated() && getRole() == 'SUPER_ADMIN';
    }
    
    function isAdmin() { return isAuthenticated() && getRole() == 'ADMIN'; }
    function isSubAdmin() { return isAuthenticated() && getRole() == 'SUB_ADMIN'; }
    function isManagement() { return isAdmin() || isSubAdmin(); }
    
    // 같은 회사 소속인지 확인 (문서의 companyId와 사용자의 companyId 비교)
    function isSameCompany(docCompanyId) {
      return getCompanyId() == docCompanyId;
    }

    // 최초 회사 생성자(Owner) 여부 확인
    function isDocCompanyOwner(docCompanyId, targetUid) {
      let companyPath = /databases/$(database)/documents/companies/$(docCompanyId);
      return exists(companyPath) && get(companyPath).data.adminUid == targetUid;
    }

    // 회사 관리 (companies)
    match /companies/{companyId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(companyId));
      allow create: if isAuthenticated(); // 회원가입 시 생성
      allow update: if isSuperAdmin() || (isAdmin() && isSameCompany(companyId));
      allow delete: if isSuperAdmin();
    }

    // 본부 관리 (divisions) - 같은 회사만 접근
    match /divisions/{divisionId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(resource.data.companyId));
      allow create: if isAuthenticated() && (isAdmin() || isSuperAdmin());
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && isSameCompany(resource.data.companyId)));
    }

    // 팀 관리 (teams) - 같은 회사만 접근
    match /teams/{teamId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(resource.data.companyId));
      allow create: if isAuthenticated() && (isAdmin() || isSuperAdmin());
      allow update, delete: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && isSameCompany(resource.data.companyId)));
    }

    // 유저/직원 프로필 관리 (UserProfile)
    match /UserProfile/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin() || isSameCompany(resource.data.companyId));
      
      allow create: if isAuthenticated();

      allow update: if isAuthenticated() && (
        (request.auth.uid == userId && (
          // 1. 본인 정보 수정 (resource.data 직접 참조로 재귀 방지)
          (resource.data.role == 'ADMIN' && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'companyId', 'status'])) ||
          (resource.data.role != 'ADMIN' && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['annualSalary', 'salaryType', 'isSeveranceIncluded', 'dependents', 'childrenUnder20', 'nonTaxable', 'rrn', 'role', 'companyId', 'status']))
        )) ||
        (request.auth.uid != userId && (
          isSuperAdmin() || 
          (isAdmin() && isSameCompany(resource.data.companyId) && (
            // 대상자가 Owner인 경우 role 및 status 수정 불가
            !isDocCompanyOwner(resource.data.companyId, userId) || 
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'status'])
          ))
        ))
      );

      allow delete: if isAuthenticated() && (isSuperAdmin() || isAdmin());
    }

    // 결재 승인 관련 유틸리티 함수
    function isSubAdminOfDivision(divId) {
      let path = /databases/$(database)/documents/UserProfile/$(request.auth.uid);
      return isSubAdmin() && exists(path) && get(path).data.divisionId == divId;
    }

    function isValidApproval(currentStatus, nextStatus, targetDivId) {
      return isAdmin() || (
        isSubAdminOfDivision(targetDivId) && 
        currentStatus == 'PENDING' && 
        (nextStatus == 'SUB_APPROVED' || nextStatus == 'REJECTED')
      );
    }

    // 경비 신청 (expenses) - 같은 회사만
    match /expenses/{expenseId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(resource.data.companyId));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING') || 
        isValidApproval(resource.data.status, request.resource.data.status, resource.data.divisionId)
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING' || isAdmin());
    }

    // 휴가 신청 (leaves) - 같은 회사만
    match /leaves/{leaveId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(resource.data.companyId));
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING') || 
        isValidApproval(resource.data.status, request.resource.data.status, resource.data.divisionId)
      );
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid && resource.data.status == 'PENDING' || isAdmin());
    }

    // 근태 기록 (attendance) - 같은 회사만
    match /attendance/{atId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(resource.data.companyId));
      allow create: if isAuthenticated() && (request.resource.data.userId == request.auth.uid);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // 공지사항 (notices) - 같은 회사만
    match /notices/{noticeId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(resource.data.companyId));
      allow write: if isManagement();
      allow delete: if isAdmin();
    }

    // 감사 로그 (AuditLogs) - 같은 회사만
    match /AuditLogs/{logId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || isSameCompany(resource.data.companyId));
      allow create: if isAuthenticated();
      allow delete: if isAdmin() || isSuperAdmin();
    }

    // 시스템 설정 (config) - 회사별 설정
    match /config/{configId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isSuperAdmin();
    }

    // 전역 시스템 설정 (system_config) - 세액표 등 (공개 데이터로 취급하여 권한 오류 방지)
    match /system_config/{configId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // 데이터 백업 작업 (backup_tasks)
    match /backup_tasks/{taskId} {
      allow read: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && isSameCompany(resource.data.companyId)));
      allow create: if isAuthenticated() && (isSuperAdmin() || (isAdmin() && isSameCompany(request.resource.data.companyId)));
      allow delete: if isSuperAdmin();
    }

    // 기본 규칙: 그 외 명시되지 않은 모든 컬렉션은 SUPER_ADMIN만 접근 가능
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
